#!/usr/bin/env bash
# Unicornsay - prints a message bubble next to a unicorn ASCII art.
# Usage:
#   ./unicornsay [--above] [--art=big|small] [--side=left|right] "message"
#   echo "message" | ./unicornsay [--above] [--art=big|small] [--side=left|right]

usage() {
  cat <<EOF
Usage: $0 [--above] [--art=big|small] [--side=left|right] "message"
       echo "message" | $0 [--above] [--art=big|small] [--side=left|right]

Options:
  --above             Show bubble above unicorn (or when terminal < 60 cols wide)
  --art=big|small     Force art size (default: auto based on terminal height)
  --side=left|right   Unicorn side when side-by-side (default: left)
EOF
}

get_unicorn_art() {
  local size="$1" side="$2"
  if [[ $size == big && $side == right ]]; then
    cat <<'EOF'
   \ ..,                 
   ;'   ',               
   .  ;'\ ',_    __.,,   
   `' .'     ~~~~  ',':  
   ,::(         (   ) ': 
  ';.  ~-..=----=. .' .' 
     '  .:'   ::  ';  '  
        (;    :'   :)    
          \.  "'   /     
         "'      "'      
EOF
  elif [[ $size == big ]]; then
    cat <<'EOF'
                ,.. /    
              ,'   ';    
   ,,.__    _,' /';  .   
  :','  ~~~~    '. '`    
  :' (   )         )::,  
  '. '. .=----=..-~  .;' 
   '  ;'  ::   ':.  '    
     (:   ':    ;)       
      \   '"  ./         
       '"      '"        
EOF
  elif [[ $side == right ]]; then
    cat <<'EOF'
   \             
   _\,,          
  "-=\~     _    
     \\~___( ~   
      _|/---\\_  
      \        \ 
EOF
  else
    cat <<'EOF'
             /   
          ,,/_   
    _     ~/=-"  
   ~ )___~//     
   _//---\|_     
  /        /     
EOF
  fi
}

message_bubble() {
  local message="$1" offset="${2:-0}"
  local cols; cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
  local wrap_width=$(( cols - 9 - offset ))
  (( wrap_width < 1 )) && wrap_width=1

  local -a lines=() words
  local len=0 cur="" word line
  while IFS= read -r line || [[ -n $line ]]; do
    if [[ -z $line ]]; then lines+=(""); continue; fi
    cur=""
    read -ra words <<< "$line"
    for word in "${words[@]}"; do
      if [[ -z $cur ]]; then cur=$word
      elif (( ${#cur} + 1 + ${#word} <= wrap_width )); then cur+=" $word"
      else lines+=("$cur"); (( ${#cur} > len )) && len=${#cur}; cur=$word
      fi
    done
    if [[ -n $cur ]]; then lines+=("$cur"); (( ${#cur} > len )) && len=${#cur}; fi
  done <<< "$message"

  local border; printf -v border '%*s' $(( len + 6 )) ''; border="${border// /─}"
  echo "┌${border}┐"
  printf "│   %-*s   │\n" "$len" ""
  for line in "${lines[@]}"; do printf "│   %-*s   │\n" "$len" "$line"; done
  printf "│   %-*s   │\n" "$len" ""
  echo "└${border}┘"
}

side_by_side() {
  local -a A B
  mapfile -t A <<< "$1"
  mapfile -t B <<< "$2"

  local widA=0 i line
  for line in "${A[@]}"; do (( ${#line} > widA )) && widA=${#line}; done

  local diff=$(( ${#B[@]} - ${#A[@]} ))
  if (( diff > 0 )); then
    local -a pad=(); for ((i=0; i<diff; i++)); do pad+=(""); done
    A=("${pad[@]}" "${A[@]}")
  elif (( diff < 0 )); then
    diff=$(( -diff ))
    local -a pad=(); for ((i=0; i<diff; i++)); do pad+=(""); done
    B=("${pad[@]}" "${B[@]}")
  fi

  for ((i=0; i<${#A[@]}; i++)); do
    printf "%-*s%s\n" "$widA" "${A[i]}" "${B[i]}"
  done
}

main() {
  local force_above=false art="" side="left" msg=""

  while (( $# )); do
    case $1 in
      --above)                   force_above=true ;;
      --art=big|--art=small)     art="${1#*=}" ;;
      --art=*)                   echo "Error: --art must be 'big' or 'small'."; exit 1 ;;
      --side=left|--side=right)  side="${1#*=}" ;;
      --side=*)                  echo "Error: --side must be 'left' or 'right'."; exit 1 ;;
      -h|--help)                 usage; exit 0 ;;
      *)                         msg="$1" ;;
    esac
    shift
  done

  [[ -p /dev/stdin && -z $msg ]] && msg=$(cat)
  [[ -z $msg ]] && { usage; exit 1; }

  local cols rows
  cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
  rows=${LINES:-$(tput lines 2>/dev/null || echo 24)}
  [[ -z $art ]] && art=$( (( rows < 15 )) && echo small || echo big )

  local art_block; art_block=$(get_unicorn_art "$art" "$side")
  local first_line="${art_block%%$'\n'*}"

  if [[ $force_above == true ]] || (( cols < 60 )); then
    message_bubble "$msg"
    if [[ $side == right ]]; then
      while IFS= read -r line; do printf "%*s\n" "$cols" "$line"; done <<< "$art_block"
    else
      echo "$art_block"
    fi
  else
    local bubble; bubble=$(message_bubble "$msg" "${#first_line}")
    if [[ $side == right ]]; then
      side_by_side "$bubble" "$art_block"
    else
      side_by_side "$art_block" "$bubble"
    fi
  fi
}

main "$@"
